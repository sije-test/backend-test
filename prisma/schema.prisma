generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  IN_PRODUCTION
  COMPLETED
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model PurchaseOrder {
  id             Int                   @id @default(autoincrement())
  productName    String                @map("product_name")
  quantity       Int
  unitPrice      Decimal               @db.Decimal(12, 2) @map("unit_price")
  specs          Json
  deliveryDate   DateTime              @db.Date @map("delivery_date")
  status         PurchaseOrderStatus   @default(DRAFT)
  currentVersion Int                   @default(0) @map("current_version")
  buyerId        String                @map("buyer_id")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  versions       PurchaseOrderVersion[]
  changeRequests ChangeRequest[]
  statusLogs     OrderStatusLog[]

  @@map("purchase_orders")
}

model PurchaseOrderVersion {
  id              Int      @id @default(autoincrement())
  orderId         Int      @map("order_id")
  version         Int
  productName     String   @map("product_name")
  quantity        Int
  unitPrice       Decimal  @db.Decimal(12, 2) @map("unit_price")
  specs           Json
  deliveryDate    DateTime @db.Date @map("delivery_date")
  changedBy       String   @map("changed_by")
  reason          String
  changeRequestId Int?     @map("change_request_id")
  createdAt       DateTime @default(now()) @map("created_at")

  order         PurchaseOrder  @relation(fields: [orderId], references: [id])
  changeRequest ChangeRequest? @relation(fields: [changeRequestId], references: [id], onDelete: Restrict)

  @@unique([orderId, version])
  @@index([orderId, createdAt, version])
  @@map("purchase_order_versions")
}

model ChangeRequest {
  id            Int                 @id @default(autoincrement())
  orderId       Int                 @map("order_id")
  requestedBy   String              @map("requested_by")
  reason        String
  changes       Json
  status        ChangeRequestStatus @default(PENDING)
  reviewedBy    String?             @map("reviewed_by")
  reviewComment String?             @map("review_comment")
  createdAt     DateTime            @default(now()) @map("created_at")
  reviewedAt    DateTime?           @map("reviewed_at")

  order    PurchaseOrder          @relation(fields: [orderId], references: [id])
  versions PurchaseOrderVersion[]

  @@map("change_requests")
}

model OrderStatusLog {
  id          Int                 @id @default(autoincrement())
  orderId     Int                 @map("order_id")
  fromStatus  PurchaseOrderStatus @map("from_status")
  toStatus    PurchaseOrderStatus @map("to_status")
  changedBy   String              @map("changed_by")
  createdAt   DateTime            @default(now()) @map("created_at")

  order PurchaseOrder @relation(fields: [orderId], references: [id])

  @@index([orderId, createdAt])
  @@map("order_status_logs")
}
